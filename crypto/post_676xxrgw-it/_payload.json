:242},"attività-e-commissioni",[244],{"type":23,"tag":31,"props":245,"children":246},{},[247],{"type":28,"value":248},"Attività e commissioni",{"type":23,"tag":24,"props":250,"children":251},{},[252,254,259,261,266],{"type":28,"value":253},"Le transazioni giornaliere su tutte le reti Layer 2 hanno raggiunto gli ",{"type":23,"tag":31,"props":255,"children":256},{},[257],{"type":28,"value":258},"8,5 milioni",{"type":28,"value":260},", mentre la mainnet di Ethereum elabora ",{"type":23,"tag":31,"props":262,"children":263},{},[264],{"type":28,"value":265},"1,2 milioni",{"type":28,"value":267}," di transazioni al giorno.",{"type":23,"tag":24,"props":269,"children":270},{},[271],{"type":23,"tag":31,"props":272,"children":273},{},[274],{"type":28,"value":275},"Commissioni medie per transazione:",{"type":23,"tag":115,"props":277,"children":278},{},[279,289,299],{"type":23,"tag":119,"props":280,"children":281},{},[282,284],{"type":28,"value":283},"Base: ",{"type":23,"tag":31,"props":285,"children":286},{},[287],{"type":28,"value":288},"$0,08",{"type":23,"tag":119,"props":290,"children":291},{},[292,294],{"type":28,"value":293},"Arbitrum: ",{"type":23,"tag":31,"props":295,"children":296},{},[297],{"type":28,"value":298},"$0,15",{"type":23,"tag":119,"props":300,"children":301},{},[302,304,309],{"type":28,"value":303},"Ethereum mainnet: ",{"type":23,"tag":31,"props":305,"children":306},{},[307],{"type":28,"value":308},"$12-25",{"type":28,"value":310}," nei periodi di picco",{"type":23,"tag":60,"props":312,"children":314},{"id":313},"lecosistema-defi-su-layer-2",[315],{"type":23,"tag":31,"props":316,"children":317},{},[318],{"type":28,"value":319},"L'ecosistema DeFi su Layer 2",{"type":23,"tag":24,"props":321,"children":322},{},[323,325,330,332,337,338,343,345,350,352,357],{"type":28,"value":324},"I protocolli ",{"type":23,"tag":31,"props":326,"children":327},{},[328],{"type":28,"value":329},"Uniswap",{"type":28,"value":331},", ",{"type":23,"tag":31,"props":333,"children":334},{