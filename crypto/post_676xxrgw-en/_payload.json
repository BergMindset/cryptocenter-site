":337},"Aave",{"type":32,"value":339},", and ",{"type":23,"tag":28,"props":341,"children":342},{},[343],{"type":32,"value":344},"Compound",{"type":32,"value":346}," protocols process significant volumes on L2 networks. Uniswap V3 on Arbitrum alone holds ",{"type":23,"tag":28,"props":348,"children":349},{},[350],{"type":32,"value":351},"$2.8 billion",{"type":32,"value":353}," in liquidity, while Base hosts more than ",{"type":23,"tag":28,"props":355,"children":356},{},[357],{"type":32,"value":358},"$1.5 billion",{"type":32,"value":360}," across various AMM protocols.",{"type":23,"tag":58,"props":362,"children":364},{"id":363},"institutional-adoption",[365],{"type":23,"tag":63,"props":366,"children":368},{"href":367},"#institutional-adoption",[369],{"type":32,"value":370},"Institutional Adoption",{"type":23,"tag":24,"props":372,"children":373},{},[374,376,381,383,388,390,395],{"type":32,"value":375},"Analysts note that the growth reflects real institutional adoption rather than a speculative bubble. Weekly active users have reached ",{"type":23,"tag":28,"props":377,"children":378},{},[379],{"type":32,"value":380},"2.3 million",{"type":32,"value":382},", and the integration of ",{"type":23,"tag":28,"props":384,"children":385},{},[386],{"type":32,"value":387},"real-world asset (RWA)",{"type":32,"value":389}," protocols has added about ",{"type":23,"tag":28,"props":391,"children":392},{},[393],{"type":32,"value":394},"$3.2 billion",{"type":32,"value":396}," to the total TVL.",{"type":23,"tag":58,"props":398,"children":400},{"id":399},"outlook",[401],{"type":23,"tag":63,"props":402,"children":404},{"href":403},"#outlook",[405],{"type":32,"value":406},"Outlook",{"type":23,"tag":24,"props":408,"children":409},{},[410,412,417,419,424],{"type":32,"value":411},"The upcoming ",{"type":23,"tag":28,"props":413,"children":414},{},[415],{"type":32,"value":416},"Cancun-Deneb",{"type":32,"value":418}," upgrade with the introduction of proto-danksharding could further reduce L2 transaction costs. If the current growth pace holds, Layer 2 networks could reach ",{"type":23,"tag":28,"props":420,"children":421},{},[422],{"type":32,"value":423},"$100 billion",{"type":32,"value":425}," in TVL by mid-2025.",{"title":7,"searchDepth":427,"depth":427,"links":428},2,[429,430,435,436,437,438],{"id":60,"depth":427,"text":68},{"id":169,"depth":427,"text":176,"children":431},[432,434],{"id":185,"depth":433,"text":192},3,{"id":221,"depth":433,"text":228},{"id":243,"depth":427,"text":250},{"id":315,"depth":427,"text":322},{"id":363,"depth":427,"text":370},{"id":399,"depth":427,"text":406},"markdown","content:crypto:post_676xxrgw-en.md","content","crypto\u002Fpost_676xxrgw-en.md","crypto\u002Fpost_676xxrgw-en","md",null,[447,455,461],{"_path":448,"title":449,"lead":450,"rubric":5,"author":451,"date":452,"cover":453,"readingTime":454},"\u002Fcrypto\u002Fmetodologiya-yldx-upravlenie-riskom","Риск в DeFi — не лотерея, а математика: методология YLDX","В 2022 году из DeFi украли $3.2 млрд — почти 6% всего рынка. Но риск в пуле ликвидности можно посчитать заранее и разложить так, что провал одного пула превращается из катастрофы в царапину. Разбираем методологию, по которой фонд YLDX выбирает пулы, делит капитал и ограничивает потери.","Редакция","2026-07-13","\u002Fcovers\u002Fyldx-risk.svg",5,{"_path":456,"title":457,"lead":458,"rubric":5,"author":451,"date":459,"cover":460,"readingTime":427},"\u002Fcrypto\u002Fsamostoyatelnoe-hranenie","«Не твои ключи — не твои монеты»: как на самом деле работает самостоятельное хранение","Криптовалюта не лежит в кошельке — она записана в блокчейне. Кошелёк хранит только ключ. Разбираем, что это значит на практике и почему одна ошибка при копировании адреса может стоить всех денег.","2026-07-08","\u002Fcovers\u002Fself-custody.svg",{"_path":462,"title":463,"lead":464,"rubric":5,"author":451,"date":465,"cover":466,"readingTime":427},"\u002Fcrypto\u002Flikvidnost-prostymi-slovami","Ликвидность простыми словами: почему в DeFi она решает всё","Пулы ликвидности заменили биржевой стакан математической формулой. Объясняем, как работает автоматический маркетмейкер, откуда берётся доходность поставщиков ликвидности и за что они на самом деле получают комиссию.","2026-06-28","\u002Fcovers\u002Fliquidity.svg",1784210110503]