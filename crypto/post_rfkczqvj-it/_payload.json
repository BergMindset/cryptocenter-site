[{"data":1,"prerenderedAt":328},["ShallowReactive",2],{"article-\u002Fcrypto\u002Fpost_rfkczqvj-it":3,"article-i18n-\u002Fcrypto\u002Fpost_rfkczqvj-it":306,"related-\u002Fcrypto\u002Fpost_rfkczqvj-it":307},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"lead":10,"rubric":5,"tags":11,"author":14,"date":15,"cover":16,"translation":17,"lang":18,"body":19,"_type":300,"_id":301,"_source":302,"_file":303,"_stem":304,"_extension":305,"readingTime":291},"\u002Fcrypto\u002Fpost_rfkczqvj-it","crypto",false,"","I Layer 2 di Ethereum raggiungono il record di $51 mld di TVL","L'ecosistema delle soluzioni Layer 2 di Ethereum ha raggiunto un traguardo storico, superando per la prima volta la soglia di $51 mld di valore totale bloccato (TVL). Questa crescita è dovuta allo sviluppo esplosivo della rete Base e al rinnovato interesse istituzionale verso le soluzioni DeFi scalabili.","Base ha superato Polygon diventando il secondo per TVL tra le soluzioni Layer 2 di Ethereum",[12,13],"notizie","cryptocenter","Redazione","2025-07-09","\u002Fimported\u002Fpost_rfkczqvj\u002Fcover.webp",true,"it",{"type":20,"children":21,"toc":290},"root",[22,45,57,76,87,132,142,151,181,193,203,208,236,245,255,260,278],{"type":23,"tag":24,"props":25,"children":26},"element","p",{},[27,30,36,38,43],{"type":28,"value":29},"text","L'ecosistema delle ",{"type":23,"tag":31,"props":32,"children":33},"strong",{},[34],{"type":28,"value":35},"soluzioni Layer 2 di Ethereum",{"type":28,"value":37}," ha raggiunto un traguardo storico, superando per la prima volta la soglia di ",{"type":23,"tag":31,"props":39,"children":40},{},[41],{"type":28,"value":42},"$51 mld",{"type":28,"value":44}," di valore totale bloccato (TVL). Questa crescita è dovuta allo sviluppo esplosivo della rete Base e al rinnovato interesse istituzionale verso le soluzioni DeFi scalabili.",{"type":23,"tag":46,"props":47,"children":49},"h2",{"id":48},"il-dominio-di-base-e-i-cambiamenti-in-classifica",[50],{"type":23,"tag":51,"props":52,"children":54},"a",{"href":53},"#il-dominio-di-base-e-i-cambiamenti-in-classifica",[55],{"type":28,"value":56},"Il dominio di Base e i cambiamenti in classifica",{"type":23,"tag":24,"props":58,"children":59},{},[60,62,67,69,74],{"type":28,"value":61},"Secondo i dati di L2Beat, il TVL complessivo di tutte le reti Layer 2 di Ethereum è cresciuto del ",{"type":23,"tag":31,"props":63,"children":64},{},[65],{"type":28,"value":66},"23% in una settimana",{"type":28,"value":68},". Il principale motore della crescita è stata la rete ",{"type":23,"tag":31,"props":70,"children":71},{},[72],{"type":28,"value":73},"Base di Coinbase",{"type":28,"value":75},", che ha ufficialmente superato Polygon conquistando il secondo posto per TVL.",{"type":23,"tag":77,"props":78,"children":80},"h3",{"id":79},"distribuzione-attuale-del-tvl",[81],{"type":23,"tag":51,"props":82,"children":84},{"href":83},"#distribuzione-attuale-del-tvl",[85],{"type":28,"value":86},"Distribuzione attuale del TVL:",{"type":23,"tag":88,"props":89,"children":90},"ul",{},[91,102,112,122],{"type":23,"tag":92,"props":93,"children":94},"li",{},[95,100],{"type":23,"tag":31,"props":96,"children":97},{},[98],{"type":28,"value":99},"Arbitrum",{"type":28,"value":101},": $18,3 mld (36% del mercato)",{"type":23,"tag":92,"props":103,"children":104},{},[105,110],{"type":23,"tag":31,"props":106,"children":107},{},[108],{"type":28,"value":109},"Base",{"type":28,"value":111},": $8,2 mld",{"type":23,"tag":92,"props":113,"children":114},{},[115,120],{"type":23,"tag":31,"props":116,"children":117},{},[118],{"type":28,"value":119},"Polygon",{"type":28,"value":121},": $7,8 mld",{"type":23,"tag":92,"props":123,"children":124},{},[125,130],{"type":23,"tag":31,"props":126,"children":127},{},[128],{"type":28,"value":129},"Optimism",{"type":28,"value":131},": $6,1 mld",{"type":23,"tag":46,"props":133,"children":135},{"id":134},"i-fattori-di-crescita-dellecosistema-layer-2",[136],{"type":23,"tag":51,"props":137,"children":139},{"href":138},"#i-fattori-di-crescita-dellecosistema-layer-2",[140],{"type":28,"value":141},"I fattori di crescita dell'ecosistema Layer 2",{"type":23,"tag":24,"props":143,"children":144},{},[145,149],{"type":23,"tag":31,"props":146,"children":147},{},[148],{"type":28,"value":109},{"type":28,"value":150}," ha mostrato indicatori di attività impressionanti:",{"type":23,"tag":88,"props":152,"children":153},{},[154,166,176],{"type":23,"tag":92,"props":155,"children":156},{},[157,159,164],{"type":28,"value":158},"Oltre ",{"type":23,"tag":31,"props":160,"children":161},{},[162],{"type":28,"value":163},"4,2 mln di transazioni",{"type":28,"value":165}," in 24 ore",{"type":23,"tag":92,"props":167,"children":168},{},[169,171],{"type":28,"value":170},"Commissioni medie inferiori a ",{"type":23,"tag":31,"props":172,"children":173},{},[174],{"type":28,"value":175},"$0,02",{"type":23,"tag":92,"props":177,"children":178},{},[179],{"type":28,"value":180},"Lancio di progetti di tokenizzazione di asset reali (RWA)",{"type":23,"tag":24,"props":182,"children":183},{},[184,186,191],{"type":28,"value":185},"Il numero totale di ",{"type":23,"tag":31,"props":187,"children":188},{},[189],{"type":28,"value":190},"indirizzi attivi",{"type":28,"value":192}," in tutte le reti L2 ha raggiunto i 2,8 mln, con un aumento del 45% rispetto al mese precedente.",{"type":23,"tag":46,"props":194,"children":196},{"id":195},"interesse-istituzionale-e-miglioramenti-tecnologici",[197],{"type":23,"tag":51,"props":198,"children":200},{"href":199},"#interesse-istituzionale-e-miglioramenti-tecnologici",[201],{"type":28,"value":202},"Interesse istituzionale e miglioramenti tecnologici",{"type":23,"tag":24,"props":204,"children":205},{},[206],{"type":28,"value":207},"Diversi fattori chiave contribuiscono alla crescita dei Layer 2:",{"type":23,"tag":88,"props":209,"children":210},{},[211,221,226],{"type":23,"tag":92,"props":212,"children":213},{},[214,219],{"type":23,"tag":31,"props":215,"children":216},{},[217],{"type":28,"value":218},"La riduzione delle commissioni",{"type":28,"value":220}," rende la DeFi accessibile agli investitori retail",{"type":23,"tag":92,"props":222,"children":223},{},[224],{"type":28,"value":225},"Gli attori istituzionali si fidano sempre di più dei modelli di sicurezza degli L2",{"type":23,"tag":92,"props":227,"children":228},{},[229,234],{"type":23,"tag":31,"props":230,"children":231},{},[232],{"type":28,"value":233},"Gli asset reali tokenizzati",{"type":28,"value":235}," rappresentano $2,8 mld del TVL complessivo",{"type":23,"tag":237,"props":238,"children":239},"blockquote",{},[240],{"type":23,"tag":24,"props":241,"children":242},{},[243],{"type":28,"value":244},"L'implementazione riuscita di EIP-4844 e il prossimo aggiornamento Dencun hanno ridotto i costi operativi degli L2 del 40%",{"type":23,"tag":46,"props":246,"children":248},{"id":247},"prospettive-di-sviluppo",[249],{"type":23,"tag":51,"props":250,"children":252},{"href":251},"#prospettive-di-sviluppo",[253],{"type":28,"value":254},"Prospettive di sviluppo",{"type":23,"tag":24,"props":256,"children":257},{},[258],{"type":28,"value":259},"Gli analisti osservano che l'ecosistema Layer 2 sta entrando in una nuova fase di adozione di massa. Sono previsti:",{"type":23,"tag":88,"props":261,"children":262},{},[263,268,273],{"type":23,"tag":92,"props":264,"children":265},{},[266],{"type":28,"value":267},"Deployment multichain dei principali protocolli",{"type":23,"tag":92,"props":269,"children":270},{},[271],{"type":28,"value":272},"Integrazione delle istituzioni finanziarie tradizionali",{"type":23,"tag":92,"props":274,"children":275},{},[276],{"type":28,"value":277},"Utilizzo degli L2 per i pagamenti transfrontalieri",{"type":23,"tag":24,"props":279,"children":280},{},[281,283,288],{"type":28,"value":282},"Lo slancio attuale potrebbe rappresentare un punto di svolta per la ",{"type":23,"tag":31,"props":284,"children":285},{},[286],{"type":28,"value":287},"DeFi scalabile",{"type":28,"value":289},", attirando potenzialmente miliardi di nuovi utenti verso la finanza decentralizzata.",{"title":7,"searchDepth":291,"depth":291,"links":292},2,[293,297,298,299],{"id":48,"depth":291,"text":56,"children":294},[295],{"id":79,"depth":296,"text":86},3,{"id":134,"depth":291,"text":141},{"id":195,"depth":291,"text":202},{"id":247,"depth":291,"text":254},"markdown","content:crypto:post_rfkczqvj-it.md","content","crypto\u002Fpost_rfkczqvj-it.md","crypto\u002Fpost_rfkczqvj-it","md",null,[308,316,322],{"_path":309,"title":310,"lead":311,"rubric":5,"author":312,"date":313,"cover":314,"readingTime":315},"\u002Fcrypto\u002Fmetodologiya-yldx-upravlenie-riskom","Риск в DeFi — не лотерея, а математика: методология YLDX","В 2022 году из DeFi украли $3.2 млрд — почти 6% всего рынка. Но риск в пуле ликвидности можно посчитать заранее и разложить так, что провал одного пула превращается из катастрофы в царапину. Разбираем методологию, по которой фонд YLDX выбирает пулы, делит капитал и ограничивает потери.","Редакция","2026-07-13","\u002Fcovers\u002Fyldx-risk.svg",5,{"_path":317,"title":318,"lead":319,"rubric":5,"author":312,"date":320,"cover":321,"readingTime":291},"\u002Fcrypto\u002Fsamostoyatelnoe-hranenie","«Не твои ключи — не твои монеты»: как на самом деле работает самостоятельное хранение","Криптовалюта не лежит в кошельке — она записана в блокчейне. Кошелёк хранит только ключ. Разбираем, что это значит на практике и почему одна ошибка при копировании адреса может стоить всех денег.","2026-07-08","\u002Fcovers\u002Fself-custody.svg",{"_path":323,"title":324,"lead":325,"rubric":5,"author":312,"date":326,"cover":327,"readingTime":291},"\u002Fcrypto\u002Flikvidnost-prostymi-slovami","Ликвидность простыми словами: почему в DeFi она решает всё","Пулы ликвидности заменили биржевой стакан математической формулой. Объясняем, как работает автоматический маркетмейкер, откуда берётся доходность поставщиков ликвидности и за что они на самом деле получают комиссию.","2026-06-28","\u002Fcovers\u002Fliquidity.svg",1784201860075]