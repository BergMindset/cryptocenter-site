":190,"children":191},{},[192],{"type":26,"value":193},"Все больше институциональных протоколов запускаются напрямую на Layer 2 решениях, минуя основную сеть Ethereum.",{"type":21,"tag":164,"props":195,"children":197},{"id":196},"развитие-инфраструктуры",[198],{"type":21,"tag":49,"props":199,"children":201},{"href":200},"#%D1%80%D0%B0%D0%B7%D0%B2%D0%B8%D1%82%D0%B8%D0%B5-%D0%B8%D0%BD%D1%84%D1%80%D0%B0%D1%81%D1%82%D1%80%D1%83%D0%BA%D1%82%D1%83%D1%80%D1%8B",[202],{"type":26,"value":203},"Развитие инфраструктуры",{"type":21,"tag":22,"props":205,"children":206},{},[207,209,214,216,221],{"type":26,"value":208},"Развертывание ",{"type":21,"tag":29,"props":210,"children":211},{},[212],{"type":26,"value":213},"Uniswap V3",{"type":26,"value":215}," на множественных Layer 2 сетях значительно увеличило концентрацию ликвидности. Ежедневные объемы торгов на Layer 2 DEX теперь составляют около ",{"type":21,"tag":29,"props":217,"children":218},{},[219],{"type":26,"value":220},"30% от общего объема",{"type":26,"value":222}," экосистемы Ethereum.",{"type":21,"tag":44,"props":224,"children":226},{"id":225},"техническое-совершенствование",[227],{"type":21,"tag":49,"props":228,"children":230},{"href":229},"#%D1%82%D0%B5%D1%85%D0%BD%D0%B8%D1%87%D0%B5%D1%81%D0%BA%D0%BE%D0%B5-%D1%81%D0%BE%D0%B2%D0%B5%D1%80%D1%88%D0%B5%D0%BD%D1%81%D1%82%D0%B2%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5",[231],{"type":26,"value":232},"Техническое совершенствование",{"type":21,"tag":22,"props":234,"children":235},{},[236],{"type":26,"value":237},"С технической точки зрения экосистема Layer 2 быстро развивается:",{"type":21,"tag":124,"props":239,"children":240},{},[241,253],{"type":21,"tag":128,"props":242,"children":243},{},[244,246,251],{"type":26,"value":245},"Arbitrum обрабатывает свыше ",{"type":21,"tag":29,"props":247,"children":248},{},[249],{"type":26,"value":250},"2 миллионов транзакций",{"type":26,"value":252}," ежедневно",{"type":21,"tag":128,"props":254,"children":255},{},[256,258,263],{"type":26,"value":257},"Base справляется с примерно ",{"type":21,"tag":29,"props":259,"children":260},{},[261],{"type":26,"value":262},"1.5 миллионами транзакций",{"type":26,"value":264}," в день",{"type":21,"tag":22,"props":266,"children":267},{},[268,270,275],{"type":26,"value":269},"Такая масштабируемость критически важна в преддверии обновления ",{"type":21,"tag":29,"props":271,"children":272},{},[273],{"type":26,"value":274},"Ethereum Dencun",{"type":26,"value":276},", которое обещает еще больше снизить стоимость транзакций в Layer 2 сетях.",{"type":21,"tag":22,"props":278,"children":279},{},[280],{"type":26,"value":281},"Достижение отметки в $50 миллиардов TVL подтверждает, что Layer 2 решения становятся неотъемлемой частью долгосрочной стратегии масштабирования Ethereum, а не временными решениями.",{"title":7,"searchDepth":283,"depth":283,"links":284},2,[285,286,287,293],{"id":46,"depth":283,"text":54},{"id":86,"depth":283,"text":93},{"id":150,"depth":283,"text":157,"children":288},[289,291,292],{"id":166,"depth":290,"text":173},3,{"id":181,"depth":290,"text":188},{"id":196,"depth":290,"text":203},{"id":225,"depth":283,"text":232},"markdown","content:crypto:post_y4bdkmd1.md","content","crypto\u002Fpost_y4bdkmd1.md","crypto\u002Fpost_y4bdkmd1","md",[301,308,314],{"_path":302,"title":303,"lead":304,"rubric":5,"author":14,"date":305,"cover":306,"readingTime":307},"\u002Fcrypto\u002Fmetodologiya-yldx-upravlenie-riskom","Риск в DeFi — не лотерея, а математика: методология YLDX","В 2022 году из DeFi украли $3.2 млрд — почти 6% всего рынка. Но риск в пуле ликвидности можно посчитать заранее и разложить так, что провал одного пула превращается из катастрофы в царапину. Разбираем методологию, по которой фонд YLDX выбирает пулы, делит капитал и ограничивает потери.","2026-07-13","\u002Fcovers\u002Fyldx-risk.svg",5,{"_path":309,"title":310,"lead":311,"rubric":5,"author":14,"date":312,"cover":313,"readingTime":283},"\u002Fcrypto\u002Fsamostoyatelnoe-hranenie","«Не твои ключи — не твои монеты»: как на самом деле работает самостоятельное хранение","Криптовалюта не лежит в кошельке — она записана в блокчейне. Кошелёк хранит только ключ. Разбираем, что это значит на практике и почему одна ошибка при копировании адреса может стоить всех денег.","2026-07-08","\u002Fcovers\u002Fself-custody.svg",{"_path":315,"title":316,"lead":317,"rubric":5,"author":14,"date":318,"cover":319,"readingTime":283},"\u002Fcrypto\u002Flikvidnost-prostymi-slovami","Ликвидность простыми словами: почему в DeFi она решает всё","Пулы ликвидности заменили биржевой стакан математической формулой. Объясняем, как работает автоматический маркетмейкер, откуда берётся доходность поставщиков ликвидности и за что они на самом деле получают комиссию.","2026-06-28","\u002Fcovers\u002Fliquidity.svg",1783948273914]