[{"data":1,"prerenderedAt":277},["ShallowReactive",2],{"article-\u002Fcrypto\u002Fpost_zrb8sb0t":3,"article-i18n-\u002Fcrypto\u002Fpost_zrb8sb0t":256,"related-\u002Fcrypto\u002Fpost_zrb8sb0t":257},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"lead":10,"rubric":5,"tags":11,"author":14,"date":15,"cover":16,"body":17,"_type":249,"_id":250,"_source":251,"_file":252,"_stem":253,"_extension":254,"readingTime":255},"\u002Fcrypto\u002Fpost_zrb8sb0t","crypto",false,"","Solana TVL превысил $9 млрд на фоне роста DeFi","Общая заблокированная стоимость (TVL) сети Solana впервые с начала 2022 года превысила отметку в $9 миллиардов. Рост обусловлен увеличением институционального интереса к DeFi и запуском крупных проектов токенизации реальных активов (RWA).","TVL Solana достиг $9 млрд впервые с 2022 года благодаря институциональному DeFi",[12,13],"новости","cryptocenter","Редакция","2025-07-09","\u002Fimported\u002Fpost_zrb8sb0t\u002Fcover.webp",{"type":18,"children":19,"toc":240},"root",[20,43,55,67,77,82,129,139,158,167,177,189,199,225,235],{"type":21,"tag":22,"props":23,"children":24},"element","p",{},[25,28,34,36,41],{"type":26,"value":27},"text","Общая заблокированная стоимость (",{"type":21,"tag":29,"props":30,"children":31},"strong",{},[32],{"type":26,"value":33},"TVL",{"type":26,"value":35},") сети Solana впервые с начала 2022 года превысила отметку в ",{"type":21,"tag":29,"props":37,"children":38},{},[39],{"type":26,"value":40},"$9 миллиардов",{"type":26,"value":42},". Рост обусловлен увеличением институционального интереса к DeFi и запуском крупных проектов токенизации реальных активов (RWA).",{"type":21,"tag":44,"props":45,"children":47},"h2",{"id":46},"рекордный-рост-экосистемы",[48],{"type":21,"tag":49,"props":50,"children":52},"a",{"href":51},"#%D1%80%D0%B5%D0%BA%D0%BE%D1%80%D0%B4%D0%BD%D1%8B%D0%B9-%D1%80%D0%BE%D1%81%D1%82-%D1%8D%D0%BA%D0%BE%D1%81%D0%B8%D1%81%D1%82%D0%B5%D0%BC%D1%8B",[53],{"type":26,"value":54},"Рекордный рост экосистемы",{"type":21,"tag":22,"props":56,"children":57},{},[58,60,65],{"type":26,"value":59},"За последние три месяца TVL Solana увеличился более чем на ",{"type":21,"tag":29,"props":61,"children":62},{},[63],{"type":26,"value":64},"180%",{"type":26,"value":66},", что позволило сети занять третье место среди DeFi-экосистем после Ethereum и Tron. Такой стремительный рост делает Solana одной из самых перспективных блокчейн-платформ для децентрализованных финансов.",{"type":21,"tag":44,"props":68,"children":70},{"id":69},"ключевые-драйверы-роста",[71],{"type":21,"tag":49,"props":72,"children":74},{"href":73},"#%D0%BA%D0%BB%D1%8E%D1%87%D0%B5%D0%B2%D1%8B%D0%B5-%D0%B4%D1%80%D0%B0%D0%B9%D0%B2%D0%B5%D1%80%D1%8B-%D1%80%D0%BE%D1%81%D1%82%D0%B0",[75],{"type":26,"value":76},"Ключевые драйверы роста",{"type":21,"tag":22,"props":78,"children":79},{},[80],{"type":26,"value":81},"Основными факторами роста стали:",{"type":21,"tag":83,"props":84,"children":85},"ul",{},[86,97,107,117],{"type":21,"tag":87,"props":88,"children":89},"li",{},[90,95],{"type":21,"tag":29,"props":91,"children":92},{},[93],{"type":26,"value":94},"Jito",{"type":26,"value":96}," — протокол стейкинга с более чем $2,1 млрд заблокированных SOL",{"type":21,"tag":87,"props":98,"children":99},{},[100,105],{"type":21,"tag":29,"props":101,"children":102},{},[103],{"type":26,"value":104},"Jupiter",{"type":26,"value":106}," — DEX-агрегатор, обработавший свыше $45 млрд торгового объема за квартал",{"type":21,"tag":87,"props":108,"children":109},{},[110,115],{"type":21,"tag":29,"props":111,"children":112},{},[113],{"type":26,"value":114},"Sanctum",{"type":26,"value":116}," — новый протокол ликвидного стейкинга",{"type":21,"tag":87,"props":118,"children":119},{},[120,122,127],{"type":26,"value":121},"Интеграция нативного выпуска ",{"type":21,"tag":29,"props":123,"children":124},{},[125],{"type":26,"value":126},"USDC",{"type":26,"value":128}," от Circle",{"type":21,"tag":44,"props":130,"children":132},{"id":131},"революция-токенизации-активов",[133],{"type":21,"tag":49,"props":134,"children":136},{"href":135},"#%D1%80%D0%B5%D0%B2%D0%BE%D0%BB%D1%8E%D1%86%D0%B8%D1%8F-%D1%82%D0%BE%D0%BA%D0%B5%D0%BD%D0%B8%D0%B7%D0%B0%D1%86%D0%B8%D0%B8-%D0%B0%D0%BA%D1%82%D0%B8%D0%B2%D0%BE%D0%B2",[137],{"type":26,"value":138},"Революция токенизации активов",{"type":21,"tag":22,"props":140,"children":141},{},[142,144,149,151,156],{"type":26,"value":143},"Миграция крупных RWA-проектов на Solana стала ключевым катализатором роста. ",{"type":21,"tag":29,"props":145,"children":146},{},[147],{"type":26,"value":148},"Ondo Finance",{"type":26,"value":150}," и ",{"type":21,"tag":29,"props":152,"children":153},{},[154],{"type":26,"value":155},"Maple Finance",{"type":26,"value":157}," перенесли значительную часть операций в сеть, отмечая более низкие комиссии и быстрые расчеты по сравнению с Ethereum Layer 2.",{"type":21,"tag":159,"props":160,"children":161},"blockquote",{},[162],{"type":21,"tag":22,"props":163,"children":164},{},[165],{"type":26,"value":166},"Токен OUSG от Ondo, представляющий токенизированные казначейские облигации США, достиг $400 млн активов под управлением на Solana — рост на 300% с сентября.",{"type":21,"tag":44,"props":168,"children":170},{"id":169},"институциональная-адаптация",[171],{"type":21,"tag":49,"props":172,"children":174},{"href":173},"#%D0%B8%D0%BD%D1%81%D1%82%D0%B8%D1%82%D1%83%D1%86%D0%B8%D0%BE%D0%BD%D0%B0%D0%BB%D1%8C%D0%BD%D0%B0%D1%8F-%D0%B0%D0%B4%D0%B0%D0%BF%D1%82%D0%B0%D1%86%D0%B8%D1%8F",[175],{"type":26,"value":176},"Институциональная адаптация",{"type":21,"tag":22,"props":178,"children":179},{},[180,182,187],{"type":26,"value":181},"Интеграция ",{"type":21,"tag":29,"props":183,"children":184},{},[185],{"type":26,"value":186},"AI-алгоритмов",{"type":26,"value":188}," для торговли и автоматизированных стратегий маркет-мейкинга привлекла квантовые торговые фирмы. Это создало положительную обратную связь, улучшив глубину ликвидности и уменьшив проскальзывание.",{"type":21,"tag":44,"props":190,"children":192},{"id":191},"технические-преимущества",[193],{"type":21,"tag":49,"props":194,"children":196},{"href":195},"#%D1%82%D0%B5%D1%85%D0%BD%D0%B8%D1%87%D0%B5%D1%81%D0%BA%D0%B8%D0%B5-%D0%BF%D1%80%D0%B5%D0%B8%D0%BC%D1%83%D1%89%D0%B5%D1%81%D1%82%D0%B2%D0%B0",[197],{"type":26,"value":198},"Технические преимущества",{"type":21,"tag":22,"props":200,"children":201},{},[202,204,209,211,216,218,223],{"type":26,"value":203},"Средняя комиссия за транзакцию в Solana составляет ",{"type":21,"tag":29,"props":205,"children":206},{},[207],{"type":26,"value":208},"$0,00025",{"type":26,"value":210}," против ",{"type":21,"tag":29,"props":212,"children":213},{},[214],{"type":26,"value":215},"$2,50",{"type":26,"value":217}," в Ethereum. Количество ежедневных активных адресов выросло на ",{"type":21,"tag":29,"props":219,"children":220},{},[221],{"type":26,"value":222},"65%",{"type":26,"value":224}," за месяц, подтверждая растущий интерес пользователей.",{"type":21,"tag":44,"props":226,"children":228},{"id":227},"перспективы-развития",[229],{"type":21,"tag":49,"props":230,"children":232},{"href":231},"#%D0%BF%D0%B5%D1%80%D1%81%D0%BF%D0%B5%D0%BA%D1%82%D0%B8%D0%B2%D1%8B-%D1%80%D0%B0%D0%B7%D0%B2%D0%B8%D1%82%D0%B8%D1%8F",[233],{"type":26,"value":234},"Перспективы развития",{"type":21,"tag":22,"props":236,"children":237},{},[238],{"type":26,"value":239},"Текущий рост TVL указывает на то, что Solana отвоевывает долю рынка у Ethereum и Layer 2 решений. Комбинация институциональной адаптации RWA, AI-стратегий и надежной DeFi-инфраструктуры создает благоприятные условия для дальнейшего роста в 2024 году.",{"title":7,"searchDepth":241,"depth":241,"links":242},2,[243,244,245,246,247,248],{"id":46,"depth":241,"text":54},{"id":69,"depth":241,"text":76},{"id":131,"depth":241,"text":138},{"id":169,"depth":241,"text":176},{"id":191,"depth":241,"text":198},{"id":227,"depth":241,"text":234},"markdown","content:crypto:post_zrb8sb0t.md","content","crypto\u002Fpost_zrb8sb0t.md","crypto\u002Fpost_zrb8sb0t","md",1,null,[258,265,271],{"_path":259,"title":260,"lead":261,"rubric":5,"author":14,"date":262,"cover":263,"readingTime":264},"\u002Fcrypto\u002Fmetodologiya-yldx-upravlenie-riskom","Риск в DeFi — не лотерея, а математика: методология YLDX","В 2022 году из DeFi украли $3.2 млрд — почти 6% всего рынка. Но риск в пуле ликвидности можно посчитать заранее и разложить так, что провал одного пула превращается из катастрофы в царапину. Разбираем методологию, по которой фонд YLDX выбирает пулы, делит капитал и ограничивает потери.","2026-07-13","\u002Fcovers\u002Fyldx-risk.svg",5,{"_path":266,"title":267,"lead":268,"rubric":5,"author":14,"date":269,"cover":270,"readingTime":241},"\u002Fcrypto\u002Fsamostoyatelnoe-hranenie","«Не твои ключи — не твои монеты»: как на самом деле работает самостоятельное хранение","Криптовалюта не лежит в кошельке — она записана в блокчейне. Кошелёк хранит только ключ. Разбираем, что это значит на практике и почему одна ошибка при копировании адреса может стоить всех денег.","2026-07-08","\u002Fcovers\u002Fself-custody.svg",{"_path":272,"title":273,"lead":274,"rubric":5,"author":14,"date":275,"cover":276,"readingTime":241},"\u002Fcrypto\u002Flikvidnost-prostymi-slovami","Ликвидность простыми словами: почему в DeFi она решает всё","Пулы ликвидности заменили биржевой стакан математической формулой. Объясняем, как работает автоматический маркетмейкер, откуда берётся доходность поставщиков ликвидности и за что они на самом деле получают комиссию.","2026-06-28","\u002Fcovers\u002Fliquidity.svg",1784030008027]