 2 от Coinbase, продемонстрировало впечатляющий рост с момента запуска основной сети. Платформа увеличила свой TVL на ",{"type":21,"tag":29,"props":144,"children":145},{},[146],{"type":26,"value":147},"340%",{"type":26,"value":149}," за последний квартал благодаря:",{"type":21,"tag":85,"props":151,"children":152},{},[153,158,163],{"type":21,"tag":89,"props":154,"children":155},{},[156],{"type":26,"value":157},"Стратегическим партнерствам",{"type":21,"tag":89,"props":159,"children":160},{},[161],{"type":26,"value":162},"Упрощенному процессу ввода фиатных средств",{"type":21,"tag":89,"props":164,"children":165},{},[166],{"type":26,"value":167},"Конкурентоспособным протоколам жидкого стейкинга",{"type":21,"tag":44,"props":169,"children":171},{"id":170},"интеграция-реальных-активов",[172],{"type":21,"tag":49,"props":173,"children":175},{"href":174},"#%D0%B8%D0%BD%D1%82%D0%B5%D0%B3%D1%80%D0%B0%D1%86%D0%B8%D1%8F-%D1%80%D0%B5%D0%B0%D0%BB%D1%8C%D0%BD%D1%8B%D1%85-%D0%B0%D0%BA%D1%82%D0%B8%D0%B2%D0%BE%D0%B2",[176],{"type":26,"value":177},"Интеграция реальных активов",{"type":21,"tag":22,"props":179,"children":180},{},[181,183,188,190,195,196,201],{"type":26,"value":182},"Значительным трендом стала интеграция протоколов реальных активов (",{"type":21,"tag":29,"props":184,"children":185},{},[186],{"type":26,"value":187},"RWA",{"type":26,"value":189},"). Платформы ",{"type":21,"tag":29,"props":191,"children":192},{},[193],{"type":26,"value":194},"Centrifuge",{"type":26,"value":71},{"type":21,"tag":29,"props":197,"children":198},{},[199],{"type":26,"value":200},"Goldfinch",{"type":26,"value":202}," расширили свои операции на Arbitrum и Polygon, внеся около $2.3 млрд в общий TVL Layer 2.",{"type":21,"tag":44,"props":204,"children":206},{"id":205},"конкурентная-динамика",[207],{"type":21,"tag":49,"props":208,"children":210},{"href":209},"#%D0%BA%D0%BE%D0%BD%D0%BA%D1%83%D1%80%D0%B5%D0%BD%D1%82%D0%BD%D0%B0%D1%8F-%D0%B4%D0%B8%D0%BD%D0%B0%D0%BC%D0%B8%D0%BA%D0%B0",[211],{"type":26,"value":212},"Конкурентная динамика",{"type":21,"tag":22,"props":214,"children":215},{},[216],{"type":26,"value":217},"Каждая платформа предлагает уникальные преимущества:",{"type":21,"tag":85,"props":219,"children":220},{},[221,230,240],{"type":21,"tag":89,"props":222,"children":223},{},[224,228],{"type":21,"tag":29,"props":225,"children":226},{},[227],{"type":26,"value":76},{"type":26,"value":229}," фокусируется на инновациях в управлении через модель Collective",{"type":21,"tag":89,"props":231,"children":232},{},[233,238],{"type":21,"tag":29,"props":234,"children":235},{},[236],{"type":26,"value":237},"Polygon",{"type":26,"value":239}," делает упор на корпоративные партнерства",{"type":21,"tag":89,"props":241,"children":242},{},[243,248,249,254],{"type":21,"tag":29,"props":244,"children":245},{},[246],{"type":26,"value":247},"Starknet",{"type":26,"value":71},{"type":21,"tag":29,"props":250,"children":251},{},[252],{"type":26,"value":253},"zkSync Era",{"type":26,"value":255}," готовятся к конкуренции с установленными игроками",{"type":21,"tag":44,"props":257,"children":259},{"id":258},"перспективы-развития",[260],{"type":21,"tag":49,"props":261,"children":263},{"href":262},"#%D0%BF%D0%B5%D1%80%D1%81%D0%BF%D0%B5%D0%BA%D1%82%D0%B8%D0%B2%D1%8B-%D1%80%D0%B0%D0%B7%D0%B2%D0%B8%D1%82%D0%B8%D1%8F",[264],{"type":26,"value":265},"Перспективы развития",{"type":21,"tag":22,"props":267,"children":268},{},[269,271,276],{"type":26,"value":270},"Аналитики прогнозируют дальнейшее ускорение роста экосистемы Layer 2 с предстоящим обновлением Ethereum ",{"type":21,"tag":29,"props":272,"children":273},{},[274],{"type":26,"value":275},"Dencun",{"type":26,"value":277},", которое может снизить стоимость транзакций на 90%. Это может подтолкнуть совокупный TVL Layer 2 к отметке $60 млрд к концу года.",{"type":21,"tag":279,"props":280,"children":281},"blockquote",{},[282],{"type":21,"tag":22,"props":283,"children":284},{},[285],{"type":26,"value":286},"Текущий рост TVL представляет собой не просто численное увеличение, а фундаментальный сдвиг к мультичейн-будущему, где решения Layer 2 служат основной инфраструктурой для DeFi-инноваций.",{"title":7,"searchDepth":288,"depth":288,"links":289},2,[290,291,292,293,294],{"id":46,"depth":288,"text":54},{"id":126,"depth":288,"text":133},{"id":170,"depth":288,"text":177},{"id":205,"depth":288,"text":212},{"id":258,"depth":288,"text":265},"markdown","content:crypto:post_jrmhmhhg.md","content","crypto\u002Fpost_jrmhmhhg.md","crypto\u002Fpost_jrmhmhhg","md",1,null,[304,311,317],{"_path":305,"title":306,"lead":307,"rubric":5,"author":14,"date":308,"cover":309,"readingTime":310},"\u002Fcrypto\u002Fmetodologiya-yldx-upravlenie-riskom","Риск в DeFi — не лотерея, а математика: методология YLDX","В 2022 году из DeFi украли $3.2 млрд — почти 6% всего рынка. Но риск в пуле ликвидности можно посчитать заранее и разложить так, что провал одного пула превращается из катастрофы в царапину. Разбираем методологию, по которой фонд YLDX выбирает пулы, делит капитал и ограничивает потери.","2026-07-13","\u002Fcovers\u002Fyldx-risk.svg",5,{"_path":312,"title":313,"lead":314,"rubric":5,"author":14,"date":315,"cover":316,"readingTime":288},"\u002Fcrypto\u002Fsamostoyatelnoe-hranenie","«Не твои ключи — не твои монеты»: как на самом деле работает самостоятельное хранение","Криптовалюта не лежит в кошельке — она записана в блокчейне. Кошелёк хранит только ключ. Разбираем, что это значит на практике и почему одна ошибка при копировании адреса может стоить всех денег.","2026-07-08","\u002Fcovers\u002Fself-custody.svg",{"_path":318,"title":319,"lead":320,"rubric":5,"author":14,"date":321,"cover":322,"readingTime":288},"\u002Fcrypto\u002Flikvidnost-prostymi-slovami","Ликвидность простыми словами: почему в DeFi она решает всё","Пулы ликвидности заменили биржевой стакан математической формулой. Объясняем, как работает автоматический маркетмейкер, откуда берётся доходность поставщиков ликвидности и за что они на самом деле получают комиссию.","2026-06-28","\u002Fcovers\u002Fliquidity.svg",1784210112065]