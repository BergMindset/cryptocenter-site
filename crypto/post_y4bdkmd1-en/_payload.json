[{"data":1,"prerenderedAt":326},["ShallowReactive",2],{"article-\u002Fcrypto\u002Fpost_y4bdkmd1-en":3,"article-i18n-\u002Fcrypto\u002Fpost_y4bdkmd1-en":304,"related-\u002Fcrypto\u002Fpost_y4bdkmd1-en":305},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"lead":10,"rubric":5,"tags":11,"author":14,"date":15,"cover":16,"translation":17,"lang":18,"body":19,"_type":298,"_id":299,"_source":300,"_file":301,"_stem":302,"_extension":303,"readingTime":287},"\u002Fcrypto\u002Fpost_y4bdkmd1-en","crypto",false,"","Ethereum Layer 2 Surpasses $50 Billion in TVL","The Ethereum Layer 2 ecosystem has reached a historic milestone, surpassing the $50 billion mark in total value locked (TVL) for the first time ever, according to data from L2Beat.","The Layer 2 ecosystem has reached $50 billion in TVL, growing 40% in a month",[12,13],"news","cryptocenter","Editorial","2025-07-09","\u002Fimported\u002Fpost_y4bdkmd1\u002Fcover.webp",true,"en",{"type":20,"children":21,"toc":286},"root",[22,45,57,69,86,96,122,127,152,162,167,178,183,193,198,208,227,237,242,269,281],{"type":23,"tag":24,"props":25,"children":26},"element","p",{},[27,30,36,38,43],{"type":28,"value":29},"text","The Ethereum ",{"type":23,"tag":31,"props":32,"children":33},"strong",{},[34],{"type":28,"value":35},"Layer 2",{"type":28,"value":37}," ecosystem has reached a historic milestone, surpassing the ",{"type":23,"tag":31,"props":39,"children":40},{},[41],{"type":28,"value":42},"$50 billion",{"type":28,"value":44}," mark in total value locked (TVL) for the first time ever, according to data from L2Beat.",{"type":23,"tag":46,"props":47,"children":49},"h2",{"id":48},"record-growth-of-scaling-solutions",[50],{"type":23,"tag":51,"props":52,"children":54},"a",{"href":53},"#record-growth-of-scaling-solutions",[55],{"type":28,"value":56},"Record growth of scaling solutions",{"type":23,"tag":24,"props":58,"children":59},{},[60,62,67],{"type":28,"value":61},"Over the past month, TVL in Layer 2 networks grew by ",{"type":23,"tag":31,"props":63,"children":64},{},[65],{"type":28,"value":66},"40%",{"type":28,"value":68},", indicating an active migration of capital away from the Ethereum mainnet. The main growth drivers were Arbitrum and Coinbase's Base, which attracted the bulk of new investments.",{"type":23,"tag":24,"props":70,"children":71},{},[72,77,79,84],{"type":23,"tag":31,"props":73,"children":74},{},[75],{"type":28,"value":76},"Arbitrum",{"type":28,"value":78}," maintains its leading position with a TVL of ",{"type":23,"tag":31,"props":80,"children":81},{},[82],{"type":28,"value":83},"$18.2 billion",{"type":28,"value":85},", accounting for roughly 36% of the entire Layer 2 market. The network shows steady growth in decentralized finance, particularly on derivatives trading platforms such as GMX and Gains Network.",{"type":23,"tag":46,"props":87,"children":89},{"id":88},"base-shows-impressive-momentum",[90],{"type":23,"tag":51,"props":91,"children":93},{"href":92},"#base-shows-impressive-momentum",[94],{"type":28,"value":95},"Base shows impressive momentum",{"type":23,"tag":24,"props":97,"children":98},{},[99,101,106,108,113,115,120],{"type":28,"value":100},"Coinbase's ",{"type":23,"tag":31,"props":102,"children":103},{},[104],{"type":28,"value":105},"Base",{"type":28,"value":107}," took second place with a TVL of ",{"type":23,"tag":31,"props":109,"children":110},{},[111],{"type":28,"value":112},"$12.8 billion",{"type":28,"value":114},", posting an incredible ",{"type":23,"tag":31,"props":116,"children":117},{},[118],{"type":28,"value":119},"180%",{"type":28,"value":121}," growth since the beginning of the year. This momentum is explained by its integration with the Coinbase retail platform and the active development of its DeFi ecosystem.",{"type":23,"tag":24,"props":123,"children":124},{},[125],{"type":28,"value":126},"Rounding out the top 4:",{"type":23,"tag":128,"props":129,"children":130},"ul",{},[131,142],{"type":23,"tag":132,"props":133,"children":134},"li",{},[135,140],{"type":23,"tag":31,"props":136,"children":137},{},[138],{"type":28,"value":139},"Polygon zkEVM",{"type":28,"value":141}," - $7.3 billion",{"type":23,"tag":132,"props":143,"children":144},{},[145,150],{"type":23,"tag":31,"props":146,"children":147},{},[148],{"type":28,"value":149},"Optimism",{"type":28,"value":151}," - $6.9 billion",{"type":23,"tag":46,"props":153,"children":155},{"id":154},"ecosystem-growth-factors",[156],{"type":23,"tag":51,"props":157,"children":159},{"href":158},"#ecosystem-growth-factors",[160],{"type":28,"value":161},"Ecosystem growth factors",{"type":23,"tag":24,"props":163,"children":164},{},[165],{"type":28,"value":166},"The migration to Layer 2 solutions is driven by several key factors:",{"type":23,"tag":168,"props":169,"children":171},"h3",{"id":170},"lower-fees",[172],{"type":23,"tag":51,"props":173,"children":175},{"href":174},"#lower-fees",[176],{"type":28,"value":177},"Lower fees",{"type":23,"tag":24,"props":179,"children":180},{},[181],{"type":28,"value":182},"High fees on the Ethereum mainnet push users to seek more cost-effective alternatives for transactions and interaction with DeFi protocols.",{"type":23,"tag":168,"props":184,"children":186},{"id":185},"institutional-adoption",[187],{"type":23,"tag":51,"props":188,"children":190},{"href":189},"#institutional-adoption",[191],{"type":28,"value":192},"Institutional adoption",{"type":23,"tag":24,"props":194,"children":195},{},[196],{"type":28,"value":197},"More and more institutional protocols are launching directly on Layer 2 solutions, bypassing the Ethereum mainnet.",{"type":23,"tag":168,"props":199,"children":201},{"id":200},"infrastructure-development",[202],{"type":23,"tag":51,"props":203,"children":205},{"href":204},"#infrastructure-development",[206],{"type":28,"value":207},"Infrastructure development",{"type":23,"tag":24,"props":209,"children":210},{},[211,213,218,220,225],{"type":28,"value":212},"The deployment of ",{"type":23,"tag":31,"props":214,"children":215},{},[216],{"type":28,"value":217},"Uniswap V3",{"type":28,"value":219}," across multiple Layer 2 networks has significantly increased liquidity concentration. Daily trading volumes on Layer 2 DEXs now account for about ",{"type":23,"tag":31,"props":221,"children":222},{},[223],{"type":28,"value":224},"30% of the total volume",{"type":28,"value":226}," of the Ethereum ecosystem.",{"type":23,"tag":46,"props":228,"children":230},{"id":229},"technical-advancement",[231],{"type":23,"tag":51,"props":232,"children":234},{"href":233},"#technical-advancement",[235],{"type":28,"value":236},"Technical advancement",{"type":23,"tag":24,"props":238,"children":239},{},[240],{"type":28,"value":241},"From a technical standpoint, the Layer 2 ecosystem is evolving rapidly:",{"type":23,"tag":128,"props":243,"children":244},{},[245,257],{"type":23,"tag":132,"props":246,"children":247},{},[248,250,255],{"type":28,"value":249},"Arbitrum processes over ",{"type":23,"tag":31,"props":251,"children":252},{},[253],{"type":28,"value":254},"2 million transactions",{"type":28,"value":256}," daily",{"type":23,"tag":132,"props":258,"children":259},{},[260,262,267],{"type":28,"value":261},"Base handles approximately ",{"type":23,"tag":31,"props":263,"children":264},{},[265],{"type":28,"value":266},"1.5 million transactions",{"type":28,"value":268}," per day",{"type":23,"tag":24,"props":270,"children":271},{},[272,274,279],{"type":28,"value":273},"Such scalability is critically important ahead of the ",{"type":23,"tag":31,"props":275,"children":276},{},[277],{"type":28,"value":278},"Ethereum Dencun",{"type":28,"value":280}," upgrade, which promises to further reduce transaction costs on Layer 2 networks.",{"type":23,"tag":24,"props":282,"children":283},{},[284],{"type":28,"value":285},"Reaching the $50 billion TVL mark confirms that Layer 2 solutions are becoming an integral part of Ethereum's long-term scaling strategy, rather than temporary fixes.",{"title":7,"searchDepth":287,"depth":287,"links":288},2,[289,290,291,297],{"id":48,"depth":287,"text":56},{"id":88,"depth":287,"text":95},{"id":154,"depth":287,"text":161,"children":292},[293,295,296],{"id":170,"depth":294,"text":177},3,{"id":185,"depth":294,"text":192},{"id":200,"depth":294,"text":207},{"id":229,"depth":287,"text":236},"markdown","content:crypto:post_y4bdkmd1-en.md","content","crypto\u002Fpost_y4bdkmd1-en.md","crypto\u002Fpost_y4bdkmd1-en","md",null,[306,314,320],{"_path":307,"title":308,"lead":309,"rubric":5,"author":310,"date":311,"cover":312,"readingTime":313},"\u002Fcrypto\u002Fmetodologiya-yldx-upravlenie-riskom","Риск в DeFi — не лотерея, а математика: методология YLDX","В 2022 году из DeFi украли $3.2 млрд — почти 6% всего рынка. Но риск в пуле ликвидности можно посчитать заранее и разложить так, что провал одного пула превращается из катастрофы в царапину. Разбираем методологию, по которой фонд YLDX выбирает пулы, делит капитал и ограничивает потери.","Редакция","2026-07-13","\u002Fcovers\u002Fyldx-risk.svg",5,{"_path":315,"title":316,"lead":317,"rubric":5,"author":310,"date":318,"cover":319,"readingTime":287},"\u002Fcrypto\u002Fsamostoyatelnoe-hranenie","«Не твои ключи — не твои монеты»: как на самом деле работает самостоятельное хранение","Криптовалюта не лежит в кошельке — она записана в блокчейне. Кошелёк хранит только ключ. Разбираем, что это значит на практике и почему одна ошибка при копировании адреса может стоить всех денег.","2026-07-08","\u002Fcovers\u002Fself-custody.svg",{"_path":321,"title":322,"lead":323,"rubric":5,"author":310,"date":324,"cover":325,"readingTime":287},"\u002Fcrypto\u002Flikvidnost-prostymi-slovami","Ликвидность простыми словами: почему в DeFi она решает всё","Пулы ликвидности заменили биржевой стакан математической формулой. Объясняем, как работает автоматический маркетмейкер, откуда берётся доходность поставщиков ликвидности и за что они на самом деле получают комиссию.","2026-06-28","\u002Fcovers\u002Fliquidity.svg",1784260194944]