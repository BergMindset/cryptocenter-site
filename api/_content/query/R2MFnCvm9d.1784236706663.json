{"type":"element","tag":"ul","props":{},"children":[{"type":"element","tag":"li","props":{},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"70% of operations"}]},{"type":"text","value":" must be conducted on Arbitrum for two years"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Payments are made in stages upon reaching milestones"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Priority is given to projects with sustainable tokenomics"}]},{"type":"element","tag":"li","props":{},"children":[{"type":"text","value":"Mandatory integration with Arbitrum's native features"}]}]},{"type":"element","tag":"h2","props":{"id":"potential-impact"},"children":[{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Potential Impact"}]}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"Analysts note that successful implementation of the program could significantly increase Arbitrum's "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"daily active users"}]},{"type":"text","value":", currently around 150,000 addresses. Gaming applications traditionally generate high transaction volumes and user activity."}]},{"type":"element","tag":"p","props":{},"children":[{"type":"text","value":"The first funding round is scheduled for "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"Q1 2024"}]},{"type":"text","value":", and major gaming projects, including "},{"type":"element","tag":"strong","props":{},"children":[{"type":"text","value":"TreasureDAO"}]},{"type":"text","value":", have already expressed interest in participating."}]}],"toc":{"title":"","searchDepth":2,"depth":2,"links":[{"id":"structure-of-the-gaming-catalyst-program","depth":2,"text":"Structure of the Gaming Catalyst Program"},{"id":"competitive-position","depth":2,"text":"Competitive Position"},{"id":"funding-